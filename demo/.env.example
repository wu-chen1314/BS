# Copy these values into your local shell before starting the backend.
# PowerShell example:
#   $env:DB_PASSWORD='12345678'
#   $env:JWT_SECRET='replace-with-a-32-byte-minimum-secret'

SERVER_PORT=8080
MAIL_HOST=smtp.qq.com
MAIL_USERNAME=your_mail@example.com
MAIL_PASSWORD=your_mail_app_password
DB_URL=jdbc:mysql://localhost:3306/ich_promotion_db?serverTimezone=Asia/Shanghai&useUnicode=true&characterEncoding=utf-8&useSSL=false
DB_USERNAME=root
DB_PASSWORD=replace-with-your-db-password
REDIS_ENABLED=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_MAX_ACTIVE=8
REDIS_MAX_WAIT=-1ms
REDIS_MAX_IDLE=8
REDIS_MIN_IDLE=0
REDIS_CONNECT_TIMEOUT=5000
REDIS_TIMEOUT=5000
JWT_SECRET=replace-with-a-32-byte-minimum-secret
JWT_EXPIRATION=86400000
DEEPSEEK_API_KEY=replace-with-your-deepseek-api-key